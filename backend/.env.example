# Environment Config

PORT=5050
HOST=0.0.0.0
NODE_ENV=development

# Database (AWS DynamoDB)
AWS_REGION=us-east-1
# Set this to a local endpoint for local testing (e.g. http://localhost:8000)
DYNAMODB_ENDPOINT=
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy

# JWT Secret for Session Management
JWT_SECRET=super_secret_jwt_key_please_change
JWT_EXPIRES_IN=24h

# Google Gemini Vision AI
GEMINI_API_KEY=your_gemini_api_key_here

# Twilio (OTP)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_sid

# AWS S3 (for Image Storage)
AWS_S3_BUCKET_NAME=your_s3_bucket
AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY_ID=dummy
AWS_S3_SECRET_ACCESS_KEY=dummy

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
EMAIL_FROM="MediManage Admin <your_email@gmail.com>"
